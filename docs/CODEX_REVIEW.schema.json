{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codex-claude-dev-loop/codex-review.schema.json",
  "title": "Codex Review Report",
  "description": "Structured review report produced by Codex for the local web task orchestrator.",
  "type": "object",
  "required": ["status", "reviewed_at", "findings"],
  "additionalProperties": true,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["PASS", "NEEDS_FIX", "BLOCKED", "FAILED"]
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "file", "description"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "file": {
            "type": "string",
            "description": "Project-relative path. Absolute paths, .. segments, and .env paths are rejected by the orchestrator."
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "fix_suggestion": {
            "type": "string"
          }
        }
      }
    }
  }
}
